# Copy to .env and adjust. docker compose reads .env automatically.
# Never commit a real .env — secrets stay out of the repo (see .gitignore).

# --- Grafana admin (secret) ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me

# --- Rate limiting (optional overrides) ---
# RATE_LIMIT_RPS=10
# RATE_LIMIT_BURST=20

# --- Auth simulated dependency latency (seconds) ---
# AUTH_DEP_LATENCY=0.08

# --- Worker job loop (seconds) ---
# WORKER_INTERVAL=5

# Future backends (not implemented yet) would add their secrets here, e.g.:
# DATABASE_URL=postgresql://user:pass@postgres:5432/autosre
# REDIS_URL=redis://redis:6379/0
