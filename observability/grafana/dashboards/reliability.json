{
  "id": null,
  "uid": "autosre-reliability",
  "title": "AutoSRE · Reliability & SLO",
  "tags": ["autosre", "slo", "sre"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "editable": true,
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    { "id": 1, "type": "row", "title": "SLO Overview", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 } },
    {
      "id": 2, "type": "stat", "title": "Availability (5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 3, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 0.995 }, { "color": "green", "value": 0.999 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [ { "refId": "A", "expr": "api:availability" } ]
    },
    {
      "id": 3, "type": "stat", "title": "Current SLO Target",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 3 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "targets": [ { "refId": "A", "expr": "api:slo_target" } ]
    },
    {
      "id": 4, "type": "gauge", "title": "Error Budget Remaining (30d)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "decimals": 1, "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 0.1 }, { "color": "green", "value": 0.5 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdLabels": false, "showThresholdMarkers": true },
      "targets": [ { "refId": "A", "expr": "clamp_min(api:error_budget_remaining, 0)" } ]
    },
    {
      "id": 5, "type": "stat", "title": "Burn Rate (1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 2, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 14.4 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [ { "refId": "A", "expr": "api:error_budget_burn_rate:1h" } ]
    },
    { "id": 6, "type": "row", "title": "Trends", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 } },
    {
      "id": 7, "type": "timeseries", "title": "Availability vs SLO",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0.99, "max": 1, "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "api:availability", "legendFormat": "availability" },
        { "refId": "B", "expr": "api:slo_target", "legendFormat": "SLO target" }
      ]
    },
    {
      "id": 8, "type": "timeseries", "title": "Error Budget Burn Rate (5m vs 1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "api:error_budget_burn_rate:5m", "legendFormat": "burn rate 5m" },
        { "refId": "B", "expr": "api:error_budget_burn_rate:1h", "legendFormat": "burn rate 1h" }
      ]
    },
    { "id": 9, "type": "row", "title": "Resilience Patterns", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 } },
    {
      "id": 10, "type": "state-timeline", "title": "Circuit Breaker State",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 80 }, "mappings": [ { "type": "value", "options": { "0": { "text": "Closed", "color": "green", "index": 0 }, "1": { "text": "Open", "color": "red", "index": 1 }, "2": { "text": "Half-Open", "color": "yellow", "index": 2 } } } ] }, "overrides": [] },
      "options": { "showValue": "auto", "mergeValues": true, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [ { "refId": "A", "expr": "max by (name) (circuit_breaker_state)", "legendFormat": "{{name}}" } ]
    },
    {
      "id": 11, "type": "timeseries", "title": "Rate Limiter Rejections",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 20 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(rate_limit_rejections_total[5m]))", "legendFormat": "rejections" },
        { "refId": "B", "expr": "sum(rate(rate_limit_requests_total[5m]))", "legendFormat": "evaluated" }
      ]
    }
  ]
}
