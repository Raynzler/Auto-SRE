{
  "id": null,
  "uid": "autosre-incident",
  "title": "AutoSRE · Incident Response",
  "tags": ["autosre", "incident", "sre"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "editable": true,
  "time": { "from": "now-3h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    { "id": 1, "type": "row", "title": "Status", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 } },
    {
      "id": 2, "type": "stat", "title": "Service Health",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "short", "mappings": [ { "type": "value", "options": { "1": { "text": "UP", "color": "green", "index": 0 }, "0": { "text": "DOWN", "color": "red", "index": 1 } } } ], "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [ { "refId": "A", "expr": "min(up{job=~\"api|auth|worker\"})" } ]
    },
    {
      "id": 3, "type": "stat", "title": "Firing Alerts",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [ { "refId": "A", "expr": "count(ALERTS{alertstate=\"firing\"}) or vector(0)" } ]
    },
    {
      "id": 4, "type": "stat", "title": "Latency p99",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 3, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 0.75 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [ { "refId": "A", "expr": "api:latency:p99" } ]
    },
    {
      "id": 5, "type": "stat", "title": "Error Rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 2, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [ { "refId": "A", "expr": "api:error_rate" } ]
    },
    { "id": 6, "type": "row", "title": "Incident Signals", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 } },
    {
      "id": 7, "type": "timeseries", "title": "Error Spikes (5xx req/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 20, "gradientMode": "opacity" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [ { "refId": "A", "expr": "sum by (status) (rate(http_requests_total{status=~\"5..\"}[1m]))", "legendFormat": "{{status}}" } ]
    },
    {
      "id": 8, "type": "timeseries", "title": "Latency Spikes (p95 / p99)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "s", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 10 }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 0.75 } ] } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "api:latency:p95", "legendFormat": "p95" },
        { "refId": "B", "expr": "api:latency:p99", "legendFormat": "p99" }
      ]
    },
    { "id": 9, "type": "row", "title": "Alert History", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 } },
    {
      "id": 10, "type": "state-timeline", "title": "Firing Alerts Over Time",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 15 },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 80 }, "color": { "mode": "fixed", "fixedColor": "red" } }, "overrides": [] },
      "options": { "showValue": "never", "mergeValues": true, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [ { "refId": "A", "expr": "ALERTS{alertstate=\"firing\"}", "legendFormat": "{{alertname}} ({{severity}})" } ]
    },
    { "id": 11, "type": "row", "title": "Failure Feed", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 } },
    {
      "id": 12, "type": "timeseries", "title": "Failure Signals (rate by source)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "custom": { "drawStyle": "bars", "fillOpacity": 60 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(chaos_events_total[5m]))", "legendFormat": "chaos events" },
        { "refId": "B", "expr": "sum(rate(circuit_breaker_open_total[5m]))", "legendFormat": "breaker opens" },
        { "refId": "C", "expr": "sum(rate(rate_limit_rejections_total[5m]))", "legendFormat": "rate-limit rejections" }
      ]
    },
    {
      "id": 13, "type": "text", "title": "Recent Failure Events & Incident Timeline",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "options": { "mode": "markdown", "content": "### Recent Failure Events\n\nRow-level failure events (chaos, circuit breaker, rate-limit) are persisted as JSONL and served by the API:\n\n```\nGET /failures?limit=50\n```\n\nThe panel on the left shows the **metric-derived** failure signal rate by source.\n\n---\n\n### Incident Timeline _(placeholder)_\n\nA future phase adds an annotated incident timeline here — correlating alert firings, deploys, and chaos experiments — via Grafana annotations + the `/failures` feed (Loki/Infinity)." }
    }
  ]
}
