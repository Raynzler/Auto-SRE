{
  "id": null,
  "uid": "autosre-red",
  "title": "AutoSRE · RED Method",
  "tags": ["autosre", "red", "sre"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "10s",
  "editable": true,
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "job",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(http_requests_total, job)",
        "query": "label_values(http_requests_total, job)",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "current": { "text": "api", "value": "api" }
      },
      {
        "name": "endpoint",
        "label": "Endpoint",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(http_requests_total{job=\"$job\"}, endpoint)",
        "query": "label_values(http_requests_total{job=\"$job\"}, endpoint)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "method",
        "label": "Method",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(http_requests_total{job=\"$job\"}, method)",
        "query": "label_values(http_requests_total{job=\"$job\"}, method)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    { "id": 1, "type": "row", "title": "Overview · $job", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 } },
    {
      "id": 2, "type": "stat", "title": "Request Rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2 }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "area" },
      "targets": [ { "refId": "A", "expr": "sum(rate(http_requests_total{job=\"$job\"}[5m]))" } ]
    },
    {
      "id": 3, "type": "stat", "title": "Error Rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "decimals": 2, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.01 }, { "color": "red", "value": 0.05 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [ { "refId": "A", "expr": "sum(rate(http_requests_total{job=\"$job\", status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total{job=\"$job\"}[5m])), 1e-9)" } ]
    },
    {
      "id": 4, "type": "stat", "title": "Latency p95",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "s", "decimals": 3, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 0.75 } ] } }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "targets": [ { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"$job\"}[5m])))" } ]
    },
    { "id": 5, "type": "row", "title": "Rate", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 } },
    {
      "id": 6, "type": "timeseries", "title": "Request Rate by Endpoint",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [ { "refId": "A", "expr": "sum by (endpoint) (rate(http_requests_total{job=\"$job\", endpoint=~\"$endpoint\", method=~\"$method\"}[5m]))", "legendFormat": "{{endpoint}}" } ]
    },
    {
      "id": 7, "type": "timeseries", "title": "Request Rate by Method",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [ { "refId": "A", "expr": "sum by (method) (rate(http_requests_total{job=\"$job\", endpoint=~\"$endpoint\", method=~\"$method\"}[5m]))", "legendFormat": "{{method}}" } ]
    },
    {
      "id": 8, "type": "timeseries", "title": "Request Rate by Status Code",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [ { "refId": "A", "expr": "sum by (status) (rate(http_requests_total{job=\"$job\", endpoint=~\"$endpoint\", method=~\"$method\"}[5m]))", "legendFormat": "{{status}}" } ]
    },
    { "id": 9, "type": "row", "title": "Errors", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 } },
    {
      "id": 10, "type": "timeseries", "title": "Error Rate (5xx ratio)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 20 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [ { "refId": "A", "expr": "sum(rate(http_requests_total{job=\"$job\", status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_requests_total{job=\"$job\"}[5m])), 1e-9)", "legendFormat": "5xx error rate" } ]
    },
    {
      "id": 11, "type": "timeseries", "title": "Error Rate by Endpoint",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [ { "refId": "A", "expr": "sum by (endpoint) (rate(http_requests_total{job=\"$job\", status=~\"5..\"}[5m])) / clamp_min(sum by (endpoint) (rate(http_requests_total{job=\"$job\"}[5m])), 1e-9)", "legendFormat": "{{endpoint}}" } ]
    },
    { "id": 12, "type": "row", "title": "Duration (Latency)", "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 } },
    {
      "id": 13, "type": "timeseries", "title": "Latency Quantiles (p50 / p95 / p99)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "s", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"$job\"}[5m])))", "legendFormat": "p50" },
        { "refId": "B", "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"$job\"}[5m])))", "legendFormat": "p95" },
        { "refId": "C", "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{job=\"$job\"}[5m])))", "legendFormat": "p99" }
      ]
    },
    {
      "id": 14, "type": "timeseries", "title": "p95 Latency by Endpoint",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "s", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [ { "refId": "A", "expr": "histogram_quantile(0.95, sum by (le, endpoint) (rate(http_request_duration_seconds_bucket{job=\"$job\", endpoint=~\"$endpoint\"}[5m])))", "legendFormat": "{{endpoint}}" } ]
    }
  ]
}
