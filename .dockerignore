# Keep build contexts small and reproducible. Most docs/assets are not needed by
# image builds; runbooks are re-included because alert tests assert they exist.
.git
.github
data
docs/*
!docs/runbooks/
!docs/runbooks/*.md
frontend
htmlcov
coverage.xml
.coverage
.pytest_cache
__pycache__
*.pyc
*.pyo
.venv
venv
dist
*.egg-info
